# Resend — get key at resend.com (free tier: 3,000 emails/mo)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Sender address. MUST be a verified Resend sender. See docs/CONTACT-EMAIL.md.
#   • Production: verify an9.dev in Resend, then use an address on it:
#     RESEND_FROM="an9.dev <contact@an9.dev>"
#   • Quick/no-DNS: leave this unset to use Resend's test sender
#     (onboarding@resend.dev) — it only delivers to your Resend account email,
#     so CONTACT_EMAIL below must be that address.
RESEND_FROM="an9.dev <contact@an9.dev>"

# hCaptcha — get at hcaptcha.com (free)
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
HCAPTCHA_SECRET=ES_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Where contact form emails land (any address once the domain is verified)
CONTACT_EMAIL=hello@an9.dev
